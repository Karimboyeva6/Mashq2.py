import random
from uz_words import words


def soz_top():
    soz = random.choice(words)
    soz = soz.upper()
    while "-" in soz or " " in soz:
        soz = random.choice(words)
        soz = soz.upper()
    return soz


def display(harflar, soz):
    y_soz = ""
    for harf in soz:
        if harf in harflar:
            y_soz += harf
        else:
            y_soz += "-"
    return y_soz


def play():
    yana = "ha"

    while yana == "ha":
        soz = soz_top()
        noyob_harflar = set(soz)
        harflar = ""
        jon = 0

        while noyob_harflar:
            print(display(harflar, soz))
            harf = input("harf kiriting: ").upper()

            if harf in harflar:
                print("bu harfni avval kiritgansiz")
                continue
            elif harf in soz:
                noyob_harflar.remove(harf)
                print(f"bu harf {harf} to'g'ri")
            else:
                print("bu harf yo'q")
                jon += 1

            harflar += harf

        print(f"tabriklaymiz siz {soz} so'zni {len(harflar)} ta taxmin bilan topdingiz va {jon} ta xato qildingiz")

        yana = input("Yana o'ynaysizmi? (ha/yo'q): ").lower()


if __name__ == "__main__":
    play()


